# Copie a `.env.local` y use valores seguros en producción.

# Secreto para firmar la cookie de sesión (≥32 caracteres).
# Puede usar AUTH_SESSION_SECRET o mantener INFORME_AUTH_SECRET por compatibilidad.
AUTH_SESSION_SECRET=reemplace-por-cadena-larga-y-aleatoria-minimo-32

# --- Personal que solo ve informes ---
AUTH_PROFESIONAL_USER=profesional
AUTH_PROFESIONAL_PASSWORD=EVS-2026-Profesional#

# --- Usuario exclusivo para registrar encuestas (no es el informe) ---
AUTH_FORMULARIO_USER=formulario
AUTH_FORMULARIO_PASSWORD=EVS-2026-Formulario#

# Compatibilidad (opcional): si existen, se usan como respaldo de usuario/contraseña profesional
# INFORME_AUTH_USER=
# INFORME_AUTH_PASSWORD=
